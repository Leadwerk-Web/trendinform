<!-- ======= USE CASES / LEISTUNGEN ======= -->
<section class="section" id="leistungen">
  <div class="container">
    <div class="section__head reveal">
      <span class="eyebrow">Unsere Leistungen</span>
      <h2>Jeder Raum hat eine Decke.<br>Wenige haben ein Konzept.</h2>
      <p>Sag uns, wo Dein Projekt spielt. Wir zeigen Dir, was darüber möglich ist.</p>
    </div>
    <div class="cases">
      <a href="#kontakt" class="case reveal" data-usecase="Badezimmer">
        <img src="assets/bad-1.jpg" alt="Weiße Hochglanz-Spanndecke mit umlaufender Lichtlinie im Badezimmer" loading="lazy">
        <div class="case__body">
          <h3>Spanndecke im Bad</h3>
          <p>Feuchtraumgeeignet, mit Spots oder Lichtlinie. Morgens montiert, abends fertig.</p>
          <span class="case__link">Kostenvoranschlag fürs Bad →</span>
        </div>
      </a>
      <a href="#kontakt" class="case reveal delay-1" data-usecase="Wohnen und Essen">
        <img src="assets/wohnen-1.jpg" alt="Esszimmer mit warmem Lichtkonzept und Pendelleuchten" loading="lazy">
        <div class="case__body">
          <h3>Wohnen und Essen</h3>
          <p>Große Flächen, Lichtzonen und dimmbare Konzepte. Nahtfrei, ruhig, wertig.</p>
          <span class="case__link">Projekt anfragen →</span>
        </div>
      </a>
      <a href="#kontakt" class="case reveal delay-2" data-usecase="Lichtlinie und Lichtkonzept">
        <img src="assets/bad-dark.jpg" alt="Schwarze Spanndecke mit präziser LED-Lichtlinie" loading="lazy">
        <div class="case__body">
          <h3>Lichtlinie und Lichtkonzept</h3>
          <p>Homogene Linien, nahezu niveaugleich in der Decke. Unsere Königsdisziplin.</p>
          <span class="case__link">Licht planen lassen →</span>
        </div>
      </a>
      <a href="#kontakt" class="case reveal" data-usecase="Akustik">
        <img src="assets/akustik-1.jpg" alt="Saal mit gewölbter Akustikdecke und Beleuchtung" loading="lazy">
        <div class="case__body">
          <h3>Akustiklösungen</h3>
          <p>Hörbar ruhigere Räume für Büro, Praxis und öffentliche Gebäude. Decke und Akustik in einem System.</p>
          <span class="case__link">Beratung anfragen →</span>
        </div>
      </a>
      <a href="#kontakt" class="case reveal delay-1" data-usecase="Reparatur oder Folientausch">
        <img src="assets/bad-4.jpg" alt="Sanierte Baddecke mit Einbaustrahlern" loading="lazy">
        <div class="case__body">
          <h3>Reparatur und Folientausch</h3>
          <p>Auch wenn andere montiert haben: Wir tauschen die Folie und setzen Deine Leuchten sauber wieder ein.</p>
          <span class="case__link">Schaden melden →</span>
        </div>
      </a>
      <a href="#kontakt" class="case reveal delay-2" data-usecase="Objekt oder Gewerbe">
        <img src="assets/objekt-1.jpg" alt="Flur mit umlaufenden LED-Lichtrahmen in einem Gewerbeobjekt" loading="lazy">
        <div class="case__body">
          <h3>Objekt und Gewerbe</h3>
          <p>Für Bauträger, Hausverwaltung und Büro: normgerecht ausgeführt, lückenlos dokumentiert, termintreu.</p>
          <span class="case__link">Angebot fürs Objekt →</span>
        </div>
      </a>
    </div>
  </div>
</section>

